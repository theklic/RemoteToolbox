# ─────────────────────────────────────────────────────────────────────────────
# RemoteToolbox environment / secrets
#
# Copy to `.env` and fill in. `.env` is gitignored — NEVER commit real secrets.
# Anything secret (API tokens, chat bot tokens, tool credentials) belongs here
# or in your own secret store, NOT in config.yaml.
# ─────────────────────────────────────────────────────────────────────────────

# --- Telegram (only needed if chat.adapter = telegram) -----------------------
# Create a bot with @BotFather on Telegram, paste the token here.
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to talk to the bot.
# Find yours by messaging @userinfobot. LEAVE EMPTY = nobody (safe default).
# This is your access control — see docs/SECURITY.md.
RTB_ALLOWED_USERS=

# --- Ollama (local LLM) ------------------------------------------------------
# Where your Ollama server is reachable. Default is a local install.
OLLAMA_HOST=http://localhost:11434

# --- Credentials for YOUR tools ----------------------------------------------
# Tools read their own secrets from the environment. Add whatever they need,
# e.g.:
#   OPENWEATHER_API_KEY=...
#   HUE_BRIDGE_TOKEN=...
